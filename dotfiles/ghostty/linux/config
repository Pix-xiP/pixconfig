# vim: set filetype=ghostty :
#
# Ghostty config :D
#
# Pix's Config
## Hotreload with CMD SHIFT ,

# Theme:
#theme = pink-n-purple-pix
theme = umbral-serenity

config-file = keybinds
 
# background-opacity = 0.85
background-opacity = 1
background-blur-radius = 30
unfocused-split-opacity = 1

## FONT:
font-family = "Maple Mono"
font-feature = +calt
font-feature = +cv01,+cv09,+cv10,+cv42,+cv43,+cv66
font-feature = +ss03,+ss07,+ss08,+ss09,+ss11
font-size = 12

# minimum-contrast = 1.1

# Cursor 
cursor-style = block
cursor-style-blink = false

# Window 
window-padding-x = 5
window-padding-y = 2
window-theme = ghostty

window-decoration = false
gtk-titlebar = false

# QoL || Misc
copy-on-select = clipboard
mouse-hide-while-typing = true
quit-after-last-window-closed = true

window-inherit-working-directory = true
window-inherit-font-size = true
working-directory = home 

# Shell specifics
shell-integration = fish
shell-integration-features = cursor,sudo,no-title

# Scrollback limit default is 1Mb. Make it 100Mb.
scrollback-limit = 1000000000
image-storage-limit = 1280000000
