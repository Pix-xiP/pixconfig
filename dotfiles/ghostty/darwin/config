# vim: set filetype=ghostty :
#
# Ghostty config :D
#
# Pix's Config
## Hotreload with CMD SHIFT ,

# Theme:
#theme = rose-pine
#theme = pink-n-purple-pix 
theme = umbral-serenity
#theme = GhostlyNight

# Keymaps
config-file = keybinds

#background-opacity = 0.80
background-opacity = 1
background-blur-radius = 30
unfocused-split-opacity = 1


## FONT:
font-family = "Maple Mono"
font-feature = +calt
font-feature = +cv01,+cv09,+cv10,+cv42,+cv43,+cv66
font-feature = +ss03,+ss07,+ss08,+ss09,+ss11

#Experimental Font
#font-family = "Departure Mono"
#font-family = "Pixel Code"
#font-size = 11.3

font-size = 11
# minimum-contrast = 1.1

# Only works on macos. Seems to look good?
font-thicken = true

# Cursor 
cursor-style = block
cursor-style-blink = false

# Window 
window-padding-x = 5
window-padding-y = 2
window-theme = ghostty

# To fix latency problems on Wavlink
window-vsync = true

# Scrollback limit default is 1Mb. Make it 100Mb.
scrollback-limit = 100000000
image-storage-limit = 128000000

# QoL || Misc
copy-on-select = clipboard
## Turn this off to stop losing cursors full time on mac atm.
#mouse-hide-while-typing = true
quit-after-last-window-closed = true

window-inherit-working-directory = true
window-inherit-font-size = true
# Because I launch from SKHD -> This will default to '/' if "inherit"
working-directory = home 
#
## Macos specific
macos-titlebar-style = tabs 
macos-option-as-alt = true

# You cannot have this and titlebar tabs enabled at the same time.
# Because you cannot have tabs without window decorations on mac.
# window-decoration = false

# Shell specifics
shell-integration = fish
shell-integration-features = cursor,sudo,no-title

command = /opt/homebrew/bin/fish --login --interactive
